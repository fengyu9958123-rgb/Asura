# AIcase 环境变量配置模板
# 本地运行可复制为 .env，Docker Compose 可直接通过环境变量覆盖。

# ============================================================
# Flask 配置
# ============================================================

# 运行环境。开源版本默认按本地开发方式运行。
FLASK_ENV=development

# 调试模式 (True/False)
DEBUG=False

# Flask 密钥（用于 session 加密）
# 生成方法: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# ============================================================
# 应用配置
# ============================================================

# 是否显示 AI 协作模块 (True/False)
SHOW_AI_COLLABORATION=True

# 服务器端口
PORT=5002

# 服务器主机
HOST=0.0.0.0

# Docker Compose 端口
AICASE_PORT=5002

# Docker Compose 持久化目录
AICASE_DATA_DIR=./runtime

# ============================================================
# 数据库配置（可选）
# ============================================================

# 数据库 URL（如果使用外部数据库）
# DATABASE_URL=postgresql://user:pass@localhost/dbname

# ============================================================
# 日志配置
# ============================================================

# 日志级别 (DEBUG/INFO/WARNING/ERROR/CRITICAL)
LOG_LEVEL=INFO

# 日志文件路径
LOG_FILE=logs/app.log

# ============================================================
# 其他配置
# ============================================================

# 上传文件大小限制（MB）
MAX_UPLOAD_SIZE=50

# 任务超时时间（秒）
TASK_TIMEOUT=3600
